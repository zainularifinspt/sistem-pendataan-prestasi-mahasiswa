    "db:docker": "docker start prestasi-postgres || docker run --name prestasi-postgres -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=prestasi_app -p 5433:5432 -v prestasi-postgres-data:/var/lib/postgresql/data -d postgres:16-alpine",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "supabase:migrate": "bash scripts/supabase-migrate.sh schema",
    "supabase:migrate:seed": "bash scripts/supabase-migrate.sh schema-seed",
    "supabase:copy-local": "bash scripts/supabase-migrate.sh copy-local"
  },
  "dependencies": {
